transcript on
if {[file exists rtl_work]} {
	vdel -lib rtl_work -all
}
vlib rtl_work
vmap work rtl_work

vlog  -work work +incdir+C:/Users/pelay/Downloads/TC2002B/UART {C:/Users/pelay/Downloads/TC2002B/UART/UART_Tx.v}
vlog  -work work +incdir+C:/Users/pelay/Downloads/TC2002B/UART {C:/Users/pelay/Downloads/TC2002B/UART/UART_Rx.v}
vlog  -work work +incdir+C:/Users/pelay/Downloads/TC2002B/UART {C:/Users/pelay/Downloads/TC2002B/UART/UART.v}

vlog  -work work +incdir+C:/Users/pelay/Downloads/TC2002B/UART {C:/Users/pelay/Downloads/TC2002B/UART/UART_Tx_tb.v}

vsim -t 1ps -L altera_ver -L lpm_ver -L sgate_ver -L altera_mf_ver -L altera_lnsim_ver -L fiftyfivenm_ver -L rtl_work -L work -voptargs="+acc"  UART_Tx_tb

add wave *
view structure
